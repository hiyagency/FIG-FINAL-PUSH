# Public site URL for canonical tags, schema, and metadata.
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Google Sheets service account configuration.
GOOGLE_PROJECT_ID="your-google-cloud-project-id"
GOOGLE_CLIENT_EMAIL="service-account-name@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="your-google-sheet-id"

# Optional sheet tab name. Defaults to Leads if omitted.
GOOGLE_SHEET_NAME="Leads"
