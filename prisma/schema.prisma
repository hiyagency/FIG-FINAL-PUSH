generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceType {
  PERSONAL
  TEAM
  AGENCY
}

enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  STRATEGIST
  APPROVER
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum BrandStatus {
  ACTIVE
  ARCHIVED
}

enum AssetKind {
  RAW_VIDEO
  PROXY_VIDEO
  AUDIO
  IMAGE
  LOGO
  MUSIC
  BROLL
  TEMPLATE
  COVER
  THUMBNAIL
  DOCUMENT
}

enum AssetSource {
  USER_UPLOAD
  GENERATED
  INTERNAL_LIBRARY
  IMPORTED_SOCIAL
  SYSTEM
}

enum AssetStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum TranscriptStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum DiagnosisStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum QuestionnaireStatus {
  DRAFT
  COMPLETED
}

enum ProjectStatus {
  DRAFT
  ANALYZING
  PLANNING
  RENDERING
  REVIEW
  READY
  PUBLISHED
  FAILED
  ARCHIVED
}

enum VersionStatus {
  DRAFT
  RENDERING
  READY
  APPROVED
  LOCKED
  FAILED
}

enum EditOperationType {
  TRIM
  CUT
  REFRAME
  SUBTITLE_STYLE
  TEXT_OVERLAY
  AUDIO_DUCK
  CTA_CARD
  WATERMARK
  BROLL
  TRANSITION
  FILTER
  LOUDNESS
  VOICE_ENHANCEMENT
  PROMPT_REWRITE
  TEMPLATE_APPLY
  COVER_FRAME
  CUSTOM
}

enum VariantType {
  AD
  ORGANIC
  TREND
  AUTHORITY
  MINIMAL
  FAST_CUT
  CUSTOM
}

enum RenderStatus {
  QUEUED
  PROCESSING
  READY
  FAILED
  CANCELED
}

enum TemplateVisibility {
  INTERNAL
  TEAM
  PRIVATE
  MARKETPLACE
}

enum PublishPlatform {
  INSTAGRAM
}

enum PublishStatus {
  DRAFT
  SCHEDULED
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELED
  NEEDS_ATTENTION
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  COMPLETED
  PROMOTED
  CANCELED
}

enum ApprovalStatus {
  PENDING
  REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  EXPIRED
  LOCKED
}

enum ThreadStatus {
  OPEN
  PENDING_APPROVAL
  NEEDS_HUMAN
  RESOLVED
  CLOSED
}

enum ThreadChannel {
  COMMENT
  DM
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  RISKY
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WEBHOOK
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
  DISMISSED
}

enum SubscriptionPlan {
  FREE
  STARTER
  GROWTH
  AGENCY
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum UsageMetric {
  STORAGE_GB
  RENDER_MINUTES
  TRANSCRIPT_MINUTES
  AI_TOKENS
  SOCIAL_PUBLISHES
  TEAM_SEATS
}

enum AuditActorType {
  USER
  SYSTEM
  API
}

enum HookStyle {
  DIRECT
  CURIOSITY
  CONTRARIAN
  AUTHORITY
  STORY
  PROBLEM_SOLUTION
  SOCIAL_PROOF
}

enum CaptionTone {
  PREMIUM
  PLAYFUL
  DIRECT_RESPONSE
  AUTHORITY
  EDUCATIONAL
}

enum FunnelGoal {
  VIEWS
  FOLLOWERS
  LEADS
  BOOKINGS
  DMS
  APP_INSTALLS
  SALES
}

enum ContentIntent {
  EDUCATIONAL
  AUTHORITY
  PROMOTIONAL
  STORYTELLING
  ENTERTAINMENT
  TESTIMONIAL
  UGC
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
  DLQ
}

enum SocialAccountStatus {
  CONNECTED
  EXPIRED
  REVOKED
  ERROR
}

enum OAuthProvider {
  CREDENTIALS
  EMAIL
  GOOGLE
  INSTAGRAM
  FACEBOOK
}

enum PublishMode {
  STANDARD
  INTERNAL_EXPERIMENT
  PLATFORM_TRIAL
}

enum ModerationDecision {
  ALLOW
  REVIEW
  HIDE
  BLOCK
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  image                String?
  locale               String?               @default("en")
  timezone             String?               @default("UTC")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  lastSeenAt           DateTime?
  accounts             Account[]
  sessions             Session[]
  passwordCredential   PasswordCredential?
  workspaceMembers     WorkspaceMember[]
  ownedWorkspaces      Workspace[]           @relation("WorkspaceOwner")
  workspaceInvitations WorkspaceInvitation[] @relation("WorkspaceInvitationSender")
  brandsCreated        Brand[]               @relation("BrandCreator")
  createdAssets        Asset[]
  projectsCreated      Project[]             @relation("ProjectCreator")
  projectVersions      ProjectVersion[]      @relation("ProjectVersionCreator")
  templatesCreated     Template[]            @relation("TemplateCreator")
  questionnaires       QuestionnaireResponse[]
  approvalRequestsMade ApprovalRequest[]     @relation("ApprovalRequester")
  approvalRequestsCompleted ApprovalRequest[] @relation("ApprovalCompleter")
  approvalComments     ApprovalComment[]
  notifications        NotificationEvent[]
  assignedThreads      EngagementThread[]    @relation("ThreadAssignee")
  savedReplies         SavedReply[]
  auditLogs            AuditLog[]            @relation("AuditActorUser")
  backgroundJobs       BackgroundJob[]       @relation("BackgroundJobCreator")
  searches             Search[]
  campaigns            Campaign[]
  leadLists            LeadList[]
  exports              Export[]
  leadSettings         LeadSettings?
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordCredential {
  id                String   @id @default(cuid())
  userId            String   @unique
  passwordHash      String
  passwordUpdatedAt DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum OtpPurpose {
  SIGNUP
  LOGIN
}

model OtpVerification {
  id           String     @id @default(cuid())
  email        String
  otpHash      String     @map("otp_hash")
  purpose      OtpPurpose
  expiresAt    DateTime   @map("expires_at")
  attemptsUsed Int        @default(0) @map("attempts_used")
  consumedAt   DateTime?  @map("consumed_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([email, purpose, createdAt])
  @@index([email, purpose, expiresAt])
  @@map("otp_verifications")
}

model Workspace {
  id                String                @id @default(cuid())
  slug              String                @unique
  name              String
  description       String?
  type              WorkspaceType
  ownerUserId       String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  owner             User                  @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  members           WorkspaceMember[]
  invitations       WorkspaceInvitation[]
  brands            Brand[]
  connectedSocialAccounts ConnectedSocialAccount[]
  assets            Asset[]
  projects          Project[]
  templates         Template[]
  subscriptions     Subscription[]
  usageCounters     UsageCounter[]
  notifications     NotificationEvent[]
  auditLogs         AuditLog[]
  publishJobs       PublishJob[]
  publishedPosts    PublishedPost[]
  analyticsSnapshots AnalyticsSnapshot[]
  experimentRuns    ExperimentRun[]
  approvalRequests  ApprovalRequest[]
  engagementThreads EngagementThread[]
  savedReplies      SavedReply[]
  backgroundJobs    BackgroundJob[]
  featureFlags      FeatureFlag[]
  questionnaires    QuestionnaireResponse[]
}

model WorkspaceMember {
  id          String           @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  status      MembershipStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, role])
}

model WorkspaceInvitation {
  id          String           @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole
  status      MembershipStatus @default(INVITED)
  token       String           @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation("WorkspaceInvitationSender", fields: [invitedById], references: [id], onDelete: Restrict)

  @@index([workspaceId, email])
}

model Brand {
  id                      String                   @id @default(cuid())
  workspaceId             String
  createdById             String
  slug                    String
  name                    String
  niche                   String?
  offerType               String?
  targetAudience          String?
  postingLanguage         String?                  @default("en")
  complianceNotes         String?
  approvalRulesSummary    String?
  status                  BrandStatus              @default(ACTIVE)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  workspace               Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy               User                     @relation("BrandCreator", fields: [createdById], references: [id], onDelete: Restrict)
  dnaProfile              BrandDnaProfile?
  connectedSocialAccounts ConnectedSocialAccount[]
  assets                  Asset[]
  projects                Project[]
  templates               Template[]
  publishJobs             PublishJob[]
  publishedPosts          PublishedPost[]
  analyticsSnapshots      AnalyticsSnapshot[]
  experimentRuns          ExperimentRun[]
  approvalRequests        ApprovalRequest[]
  engagementThreads       EngagementThread[]
  notifications           NotificationEvent[]
  auditLogs               AuditLog[]
  savedReplies            SavedReply[]
  questionnaires          QuestionnaireResponse[]
  growthMemory            GrowthMemory?
  backgroundJobs          BackgroundJob[]

  @@unique([workspaceId, slug])
}

model BrandDnaProfile {
  id                       String   @id @default(cuid())
  brandId                  String   @unique
  brandName                String
  niche                    String?
  offerType                String?
  targetAudience           String?
  preferredCaptionStyle    String?
  preferredHookStyle       String?
  pacingStyle              String?
  transitionAggressiveness Int      @default(40)
  subtitleStyle            Json?
  fontPreferences          Json?
  colorPalette             Json?
  logoAssetIds             String[] @default([])
  ctaTone                  String?
  bannedWords              String[] @default([])
  preferredWords           String[] @default([])
  audioVibe                String?
  platformGoals            String[] @default([])
  postingLanguages         String[] @default([])
  complianceNotes          String?
  approvalRules            Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  brand                    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

model ConnectedSocialAccount {
  id                    String              @id @default(cuid())
  workspaceId           String
  brandId               String
  provider              PublishPlatform
  status                SocialAccountStatus @default(CONNECTED)
  username              String?
  accountLabel          String?
  externalAccountId     String
  encryptedAccessToken  String              @db.Text
  encryptedRefreshToken String?             @db.Text
  scopes                String[]            @default([])
  expiresAt             DateTime?
  capabilities          Json?
  errorState            Json?
  lastValidatedAt       DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  workspace             Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand                 Brand               @relation(fields: [brandId], references: [id], onDelete: Cascade)
  publishedPosts        PublishedPost[]
  threads               EngagementThread[]

  @@unique([provider, externalAccountId])
  @@index([workspaceId, brandId, status])
}

model Asset {
  id                 String                @id @default(cuid())
  workspaceId        String
  brandId            String?
  createdById        String?
  kind               AssetKind
  source             AssetSource
  status             AssetStatus           @default(UPLOADING)
  fileName           String
  mimeType           String
  storageKey         String                @unique
  checksumSha256     String?
  sizeBytes          BigInt
  width              Int?
  height             Int?
  durationMs         Int?
  metadata           Json?
  tags               String[]              @default([])
  duplicateOfId      String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  workspace          Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand              Brand?                @relation(fields: [brandId], references: [id], onDelete: SetNull)
  duplicateOf        Asset?                @relation("DuplicateAsset", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates         Asset[]               @relation("DuplicateAsset")
  sourceMediaFile    MediaFile?            @relation("SourceAsset")
  proxyForMediaFiles MediaFile[]           @relation("ProxyAsset")
  thumbnailForMedia  MediaFile[]           @relation("ThumbnailAsset")
  waveformForMedia   MediaFile[]           @relation("WaveformAsset")
  renderVariants     GeneratedVariant[]    @relation("VariantRenderAsset")
  coverVariants      GeneratedVariant[]    @relation("VariantCoverAsset")
  creator            User?                 @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([workspaceId, brandId, kind, status])
  @@index([checksumSha256])
}

model MediaFile {
  id                 String      @id @default(cuid())
  assetId            String      @unique
  proxyAssetId       String?
  thumbnailAssetId   String?
  waveformAssetId    String?
  ingestStatus       AssetStatus @default(PROCESSING)
  aspectRatio        String?
  orientation        String?
  durationMs         Int?
  fps                Float?
  loudnessLufs       Float?
  sceneMarkers       Json?
  silenceMarkers     Json?
  speakerTurns       Json?
  faceRegions        Json?
  metadataExtracted  Json?
  duplicateSignature String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  asset              Asset       @relation("SourceAsset", fields: [assetId], references: [id], onDelete: Cascade)
  proxyAsset         Asset?      @relation("ProxyAsset", fields: [proxyAssetId], references: [id], onDelete: SetNull)
  thumbnailAsset     Asset?      @relation("ThumbnailAsset", fields: [thumbnailAssetId], references: [id], onDelete: SetNull)
  waveformAsset      Asset?      @relation("WaveformAsset", fields: [waveformAssetId], references: [id], onDelete: SetNull)
  transcript         Transcript?
  diagnosis          ContentDiagnosis?
  projects           Project[]

  @@index([duplicateSignature])
}

model Transcript {
  id         String           @id @default(cuid())
  mediaFileId String          @unique
  status     TranscriptStatus @default(PENDING)
  provider   String?
  language   String?
  confidence Float?
  rawText    String?          @db.Text
  segments   Json?
  words      Json?
  speakerMap Json?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  mediaFile  MediaFile        @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
}

model ContentDiagnosis {
  id                      String          @id @default(cuid())
  mediaFileId             String          @unique
  status                  DiagnosisStatus @default(PENDING)
  nicheDetected           String?
  contentIntent           ContentIntent?
  likelyPlatformFit       String[]        @default([])
  emotionalTone           String?
  speakerEnergyScore      Float?
  hookStrengthScore       Float?
  ctaPresenceScore        Float?
  productMentionScore     Float?
  facePresenceScore       Float?
  sceneChangeFrequency    Float?
  deadAirRatio            Float?
  retentionRiskScore      Float?
  adLikeVsOrganicScore    Float?
  evergreenPotentialScore Float?
  strongestAngles         String[]        @default([])
  weakPoints              String[]        @default([])
  recommendedReelTypes    String[]        @default([])
  recommendedEditingStyle String?
  bestAspectSuggestions   String[]        @default([])
  bestPlatformSuggestions String[]        @default([])
  structuredOutput        Json?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  mediaFile               MediaFile       @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  projects                Project[]
  questionnaires          QuestionnaireResponse[]
}

model QuestionnaireResponse {
  id                String              @id @default(cuid())
  workspaceId       String
  brandId           String?
  projectId         String?             @unique
  sourceDiagnosisId String?
  createdById       String?
  status            QuestionnaireStatus @default(DRAFT)
  askedQuestions    Json?
  answers           Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand             Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  sourceDiagnosis   ContentDiagnosis?   @relation(fields: [sourceDiagnosisId], references: [id], onDelete: SetNull)
  project           Project?
  createdBy         User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([workspaceId, brandId, status])
}

model Project {
  id                    String                 @id @default(cuid())
  workspaceId           String
  brandId               String
  sourceMediaId         String
  diagnosisId           String?
  questionnaireId       String?                @unique
  currentVersionId      String?                @unique
  createdById           String
  title                 String
  description           String?
  status                ProjectStatus          @default(DRAFT)
  funnelGoal            FunnelGoal
  contentIntent         ContentIntent?
  preferredLanguage     String?
  requestedVariantCount Int                    @default(3)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  workspace             Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand                 Brand                  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  sourceMedia           MediaFile              @relation(fields: [sourceMediaId], references: [id], onDelete: Restrict)
  diagnosis             ContentDiagnosis?      @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
  questionnaire         QuestionnaireResponse? @relation(fields: [questionnaireId], references: [id], onDelete: SetNull)
  currentVersion        ProjectVersion?        @relation("ProjectCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  createdBy             User                   @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  versions              ProjectVersion[]       @relation("ProjectVersions")
  variants              GeneratedVariant[]
  captionPackages       CaptionPackage[]
  hookPackages          HookPackage[]
  publishJobs           PublishJob[]
  analyticsSnapshots    AnalyticsSnapshot[]
  experimentRuns        ExperimentRun[]
  approvalRequests      ApprovalRequest[]
  backgroundJobs        BackgroundJob[]

  @@index([workspaceId, brandId, status])
}

model ProjectVersion {
  id                String           @id @default(cuid())
  projectId         String
  createdById       String
  templateVersionId String?
  versionNumber     Int
  name              String
  status            VersionStatus    @default(DRAFT)
  editDecisionList  Json?
  renderPlan        Json?
  subtitleTrack     Json?
  overlayTrack      Json?
  audioTrack        Json?
  coverFrameMs      Int?
  promptContext     Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  lockedAt          DateTime?
  project           Project          @relation("ProjectVersions", fields: [projectId], references: [id], onDelete: Cascade)
  currentForProject Project?         @relation("ProjectCurrentVersion")
  createdBy         User             @relation("ProjectVersionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  templateVersion   TemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  editOperations    EditOperation[]
  variants          GeneratedVariant[]
  approvalRequests  ApprovalRequest[] @relation("ApprovalLockedVersion")

  @@unique([projectId, versionNumber])
  @@index([projectId, status])
}

model EditOperation {
  id               String            @id @default(cuid())
  projectVersionId String
  operationType    EditOperationType
  sequence         Int
  summary          String?
  payload          Json
  idempotencyKey   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  projectVersion   ProjectVersion    @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)

  @@unique([projectVersionId, sequence])
  @@index([idempotencyKey])
}

model GeneratedVariant {
  id                     String          @id @default(cuid())
  projectId              String
  projectVersionId       String
  renderAssetId          String?
  coverAssetId           String?
  renderJobId            String?
  variantType            VariantType
  name                   String
  renderStatus           RenderStatus    @default(QUEUED)
  hookStrategy           String?
  pacingStyle            String?
  captionTreatment       String?
  ctaFraming             String?
  thumbnailSuggestion    String?
  platformRecommendation String?
  confidenceNotes        String[]        @default([])
  outputDurationMs       Int?
  renderCostUsd          Decimal?        @db.Decimal(10, 2)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  project                Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectVersion         ProjectVersion  @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)
  renderAsset            Asset?          @relation("VariantRenderAsset", fields: [renderAssetId], references: [id], onDelete: SetNull)
  coverAsset             Asset?          @relation("VariantCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  renderJob              BackgroundJob?  @relation(fields: [renderJobId], references: [id], onDelete: SetNull)
  captionPackage         CaptionPackage?
  hookPackage            HookPackage?
  publishJobs            PublishJob[]
  publishedPosts         PublishedPost[]
  analyticsSnapshots     AnalyticsSnapshot[]
  experimentRunsAsBaseline ExperimentRun[] @relation("ExperimentBaselineVariant")
  experimentRunsAsWinner ExperimentRun[]   @relation("ExperimentWinnerVariant")
  approvalRequests       ApprovalRequest[]

  @@index([projectId, variantType, renderStatus])
}

model Template {
  id                 String             @id @default(cuid())
  workspaceId        String?
  brandId            String?
  createdById        String
  slug               String
  name               String
  description        String?
  visibility         TemplateVisibility @default(PRIVATE)
  idealNiches        String[]           @default([])
  complexityScore    Int                @default(1)
  pacingStyle        String?
  captionStyle       String?
  transitions        Json?
  textAnimationStyle String?
  audioMood          String?
  ctaPattern         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  workspace          Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  brand              Brand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  createdBy          User               @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: Restrict)
  versions           TemplateVersion[]

  @@unique([createdById, slug])
  @@index([workspaceId, brandId, visibility])
}

model TemplateVersion {
  id              String           @id @default(cuid())
  templateId      String
  versionNumber   Int
  changelog       String?
  data            Json
  isPublished     Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  template        Template         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  projectVersions ProjectVersion[]

  @@unique([templateId, versionNumber])
}

model CaptionPackage {
  id                String            @id @default(cuid())
  projectId         String
  variantId         String?           @unique
  tone              CaptionTone?
  primaryCaption    String            @db.Text
  shortCaption      String?
  longCaption       String?           @db.Text
  platformCaptions  Json?
  hashtags          String[]          @default([])
  primaryKeyword    String?
  secondaryKeywords String[]          @default([])
  seoTitle          String?
  coverText         String?
  pinnedComment     String?
  ctaText           String?
  audienceAngle     String?
  postingNotes      String?
  engagementPrompts Json?
  alternativeTones  Json?
  whyThisMayWork    String?
  readabilityScore  Float?
  riskWarnings      String[]          @default([])
  overuseWarnings   String[]          @default([])
  originalityScore  Float?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
