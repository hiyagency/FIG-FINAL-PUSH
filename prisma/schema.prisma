model ApprovalRequest {
  id              String            @id @default(cuid())
  workspaceId     String
  brandId         String
  projectId       String
  variantId       String?
  lockedVersionId String?
  requestedById   String
  approvedById    String?
  status          ApprovalStatus    @default(PENDING)
  reviewLinkToken String            @unique
  dueAt           DateTime?
  requestedAt     DateTime          @default(now())
  approvedAt      DateTime?
  changeSummary   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand           Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  variant         GeneratedVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  lockedVersion   ProjectVersion?   @relation("ApprovalLockedVersion", fields: [lockedVersionId], references: [id], onDelete: SetNull)
  requestedBy     User              @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedBy      User?             @relation("ApprovalCompleter", fields: [approvedById], references: [id], onDelete: SetNull)
  comments        ApprovalComment[]

  @@index([workspaceId, brandId, status])
}

model ApprovalComment {
  id                String          @id @default(cuid())
  approvalRequestId String
  authorId          String?
  authorName        String?
  authorEmail       String?
  body              String          @db.Text
  marker            Json?
  createdAt         DateTime        @default(now())
  resolvedAt        DateTime?
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  author            User?           @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model EngagementThread {
  id               String                  @id @default(cuid())
  workspaceId      String
  brandId          String
  socialAccountId  String?
  platformThreadId String
  channel          ThreadChannel
  status           ThreadStatus            @default(OPEN)
  sentiment        Sentiment               @default(NEUTRAL)
  leadIntentScore  Float?                  @default(0)
  assignedToId     String?
  contactHandle    String?
  tags             String[]                @default([])
  metadata         Json?
  lastMessageAt    DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  workspace        Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand            Brand                   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  socialAccount    ConnectedSocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
