  brand                  Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  project                Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  variant                GeneratedVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  publishedPost          PublishedPost?    @relation(fields: [publishedPostId], references: [id], onDelete: SetNull)

