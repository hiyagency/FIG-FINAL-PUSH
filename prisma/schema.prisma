  winningCaptionTones String[] @default([])
  winningCtaTypes     String[] @default([])
  winningDurationRanges Json?
  winningPostWindows  Json?
  winningStylesByGoal Json?
  recommendations     Json?
  refreshedAt         DateTime @default(now())
  brand               Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

model SavedReply {
  id               String        @id @default(cuid())
  workspaceId      String
  brandId          String?
  userId           String?
  name             String
  triggerKeywords  String[]      @default([])
  channel          ThreadChannel
  body             String        @db.Text
  requiresApproval Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand            Brand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  user             User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model BackgroundJob {
  id             String      @id @default(cuid())
  workspaceId    String?
  brandId        String?
  projectId      String?
  createdById    String?
  queueName      String
  jobName        String
  status         JobStatus   @default(QUEUED)
  externalJobId  String?     @unique
  idempotencyKey String?     @unique
  payload        Json?
  result         Json?
  errorMessage   String?
  attempts       Int         @default(0)
  maxAttempts    Int         @default(3)
  costUsd        Decimal?    @db.Decimal(10, 2)
  startedAt      DateTime?
  finishedAt     DateTime?
  canceledAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  workspace      Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  brand          Brand?      @relation(fields: [brandId], references: [id], onDelete: SetNull)
