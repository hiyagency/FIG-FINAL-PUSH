  headlineOptions     String[]          @default([])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  project             Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  variant             GeneratedVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([projectId, businessGoal])
}

model PublishJob {
