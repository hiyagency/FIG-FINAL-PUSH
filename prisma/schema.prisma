model AnalyticsSnapshot {
  id                     String            @id @default(cuid())
  workspaceId            String
  brandId                String
  projectId              String?
  variantId              String?
  publishedPostId        String?
  platform               PublishPlatform
  capturedAt             DateTime
  impressions            Int               @default(0)
  views                  Int               @default(0)
  watchTimeMs            Int               @default(0)
  averageWatchDurationMs Int               @default(0)
  retentionDropoffHints  Json?
  saves                  Int               @default(0)
  shares                 Int               @default(0)
  comments               Int               @default(0)
  profileVisits          Int               @default(0)
  follows                Int               @default(0)
  dmsTriggered           Int               @default(0)
  conversions            Int               @default(0)
  captionLength          Int?
  hookStyle              String?
  subtitleStyle          String?
  pacingStyle            String?
  templateFamily         String?
  ctaFamily              String?
