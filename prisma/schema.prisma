model FeatureFlag {
  id          String    @id @default(cuid())
  workspaceId String
  key         String
  enabled     Boolean   @default(false)
  config      Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
}

enum SearchStatus {
  DRAFT
  QUEUED
  RUNNING
  PARTIAL
  COMPLETE
  FAILED
  CANCELED
}

enum SearchJobStage {
  PARSE
  SEARCH
  DIRECTORY
  ENRICH
  AUDIT
  CONTACTS
  DEDUPE
  SCORE
  RANK
  EXPORT
}

enum SearchJobStatus {
  QUEUED
  RUNNING
  PARTIAL
  COMPLETE
  FAILED
  CANCELED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ExportFormat {
  CSV
  XLSX
}

enum ExportStatus {
  QUEUED
  RUNNING
  COMPLETE
  FAILED
}

model Search {
  id              String        @id @default(cuid())
  userId          String
  name            String?
  rawPrompt       String        @db.Text
  status          SearchStatus  @default(DRAFT)
  resultLimit     Int           @default(50)
  sortBy          String        @default("highest_opportunity")
  progressPercent Int           @default(0)
  currentMessage  String?
  summary         Json?
  isSaved         Boolean       @default(false)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parsedQuery     ParsedQuery?
  jobs            SearchJob[]
  leadScores      LeadScore[]
  searchLeads     SearchLead[]
  exports         Export[]
  campaignLeads   CampaignLead[]
  leadListLeads   LeadListLead[]

  @@index([userId, status, createdAt])
}

model ParsedQuery {
  id                 String    @id @default(cuid())
  searchId           String    @unique
  rawJson            Json
  industries         String[]  @default([])
  serviceNeeds       String[]  @default([])
  businessSize       String?
  contactPreferences String[]  @default([])
  signals            String[]  @default([])
  constraints        Json?
  locationCountry    String?
  locationState      String?
  locationCity       String?
  language           String?
  approved           Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  search             Search    @relation(fields: [searchId], references: [id], onDelete: Cascade)
}

model SearchJob {
  id           String          @id @default(cuid())
  searchId     String
  stage        SearchJobStage
  connectorKey String?
  status       SearchJobStatus @default(QUEUED)
  progress     Int             @default(0)
  message      String?
  logs         Json?
  input        Json?
  result       Json?
  errorMessage String?
  attempts     Int             @default(0)
  maxAttempts  Int             @default(3)
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  search       Search          @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@index([searchId, status, stage])
}

model Lead {
  id                        String          @id @default(cuid())
  companyName               String
  normalizedCompanyName     String
  contactName               String?
  contactRole               String?
  businessEmail             String?
  businessPhone             String?
  website                   String?
  domain                    String?
  industry                  String?
  subIndustry               String?
  country                   String?
  state                     String?
  city                      String?
  address                   String?
  googleRating              Float?
  reviewSummary             String?
  employeeSizeEstimate      String?
  revenueEstimateOptional   String?
  socialLinks               Json?
  sourceUrls                String[]        @default([])
  sourceNames               String[]        @default([])
  sourceCount               Int             @default(0)
  websiteQualityScore       Int?
  mobileFriendlinessScore   Int?
  seoScore                  Int?
  brandingScore             Int?
  speedScore                Int?
  adActivitySignal          Boolean         @default(false)
  crmSignal                 Boolean         @default(false)
  bookingSignal             Boolean         @default(false)
  outdatedWebsiteSignal     Boolean         @default(false)
  noWebsiteSignal           Boolean         @default(false)
  weakSocialPresenceSignal  Boolean         @default(false)
  painPoints                String[]        @default([])
  aiSummary                 String?         @db.Text
  outreachAngle             String?         @db.Text
  bestOfferToPitch          String?
  coldOpenerLine            String?
  whyNow                    String?
  priorityLevel             String?
  opportunityScore          Int             @default(0)
  fitScore                  Int             @default(0)
  confidenceScore           Int             @default(0)
  latestAudit               Json?
  tags                      String[]        @default([])
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  leadSources               LeadSource[]
  leadScores                LeadScore[]
  searchLeads               SearchLead[]
  campaignLeads             CampaignLead[]
  leadListLeads             LeadListLead[]

  @@index([normalizedCompanyName])
  @@index([domain])
  @@index([country, state, city])
}

model LeadSource {
  id              String   @id @default(cuid())
  leadId          String
  connectorName   String
  sourceName      String
  sourceUrl       String
  fieldName       String?
  fieldValue      String?
  fieldConfidence Int?
  evidence        Json?
  createdAt       DateTime @default(now())
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, connectorName])
}

model LeadScore {
  id               String   @id @default(cuid())
  searchId         String
  leadId           String
  opportunityScore Int
  fitScore         Int
  confidenceScore  Int
  scoreBreakdown   Json
  rationale        String?  @db.Text
  createdAt        DateTime @default(now())
  search           Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([searchId, leadId])
  @@index([opportunityScore, fitScore])
}

model SearchLead {
  id         String   @id @default(cuid())
  searchId   String
  leadId     String
  rank       Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  search     Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([searchId, leadId])
  @@index([searchId, rank])
}

model Campaign {
  id           String          @id @default(cuid())
  userId       String
  name         String
  slug         String
  description  String?
  status       CampaignStatus  @default(ACTIVE)
  defaultPitch String?
  tags         String[]        @default([])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads        CampaignLead[]
  exports      Export[]

  @@unique([userId, slug])
  @@index([userId, status])
}

model CampaignLead {
  id              String   @id @default(cuid())
  campaignId      String
  leadId          String
  addedBySearchId String?
  stage           String   @default("queued")
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  addedBySearch   Search?  @relation(fields: [addedBySearchId], references: [id], onDelete: SetNull)

  @@unique([campaignId, leadId])
  @@index([campaignId, stage])
}

model LeadList {
  id          String        @id @default(cuid())
  userId      String
  name        String
  slug        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads       LeadListLead[]
  exports     Export[]

  @@unique([userId, slug])
  @@index([userId, createdAt])
}

model LeadListLead {
  id        String   @id @default(cuid())
  listId     String
  leadId     String
  searchId   String?
  createdAt  DateTime @default(now())
  list       LeadList @relation(fields: [listId], references: [id], onDelete: Cascade)
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  search     Search?  @relation(fields: [searchId], references: [id], onDelete: SetNull)

  @@unique([listId, leadId])
  @@index([listId, createdAt])
}

model Export {
  id          String       @id @default(cuid())
  userId      String
  searchId    String?
  campaignId  String?
  listId      String?
  format      ExportFormat
  status      ExportStatus @default(QUEUED)
  fileName    String
  storageKey  String?
  rowCount    Int          @default(0)
  filters     Json?
  errorMessage String?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  search      Search?      @relation(fields: [searchId], references: [id], onDelete: SetNull)
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  list        LeadList?    @relation(fields: [listId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
}

model LeadSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  connectorToggles  Json?
  complianceText    String?  @db.Text
  enrichmentDepth   String   @default("standard")
  dedupeSettings    Json?
  exportDefaults    Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
