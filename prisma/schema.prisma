  @@unique([channel, platformThreadId])
  @@index([workspaceId, brandId, status])
}

model CommentEvent {
  id                 String             @id @default(cuid())
  threadId           String
  socialCommentId    String             @unique
  authorHandle       String?
  authorDisplayName  String?
